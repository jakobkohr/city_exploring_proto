# .env.local — NEVER commit this file. Add to .gitignore immediately.
# Copy this file to .env.local and fill in your keys.

GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: for Google Maps Embed (uses Embed API, different from Places API)
# NEXT_PUBLIC_GMAPS_EMBED_KEY=your_maps_embed_key_here
